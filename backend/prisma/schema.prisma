// FILE: prisma/schema.prisma
// CAMBIO: Agrega modelo LiquidacionPedido para la relación N:M entre
// Liquidacion y Pedido. El resto del schema no se modifica.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Rol {
  ADMIN
  SECRETARIO
}

enum EstadoPedido {
  ACTIVO
  FACTURADO
  ANULADO
}

enum EstadoFactura {
  EMITIDA
  PAGADA
  PENDIENTE
  PARCIAL
  ANULADA
}

enum EstadoCaja {
  ABIERTA
  CERRADA
}

enum TipoMovimientoCaja {
  INGRESO
  EGRESO
}

enum CondicionPago {
  CONTADO
  CREDITO_15
  CREDITO_30
  CREDITO_60
}

// ─── MODELOS ─────────────────────────────────────────────────────────────────

model Usuario {
  id             Int      @id @default(autoincrement())
  nombre         String
  email          String   @unique
  passwordHash   String   @map("password_hash")
  rol            Rol      @default(SECRETARIO)
  activo         Boolean  @default(true)
  ultimoAcceso   DateTime? @map("ultimo_acceso")
  creadoEn       DateTime @default(now()) @map("creado_en")
  actualizadoEn  DateTime @updatedAt @map("actualizado_en")

  // ── Restricción de horario de acceso (por usuario) ──────────────────────
  // Si restriccionHorarioActiva es true, el usuario solo puede iniciar sesión
  // y usar el sistema dentro de diasPermitidos (1=Lunes...7=Domingo) y entre
  // horaInicio y horaFin ("HH:mm", hora Perú). ADMIN nunca se restringe.
  restriccionHorarioActiva Boolean  @default(false) @map("restriccion_horario_activa")
  diasPermitidos           Int[]    @default([1, 2, 3, 4, 5]) @map("dias_permitidos")
  horaInicio               String?  @map("hora_inicio")
  horaFin                  String?  @map("hora_fin")

  pedidos        Pedido[]
  facturas       Factura[]
  cajas          Caja[]
  logs           LogActividad[]

  permisosModulos  PermisoModulo[]
  permisosAcciones PermisoAccion[]
  movimientosCuentaV2 MovimientoCuentaV2[]
  pagosV2          PagoV2[]
  guias            Guia[]

  @@map("usuarios")
}

model Cliente {
  id             Int           @id @default(autoincrement())
  razonSocial    String        @map("razon_social")
  ruc            String        @unique
  direccion      String
  // Ubigeo (código INEI de 6 dígitos) del cliente — se usa para autocompletar
  // el punto de llegada al seleccionar el cliente en una Guía de Remisión.
  ubigeo         String?
  telefono       String?
  email          String?
  condicionPago  CondicionPago @default(CONTADO) @map("condicion_pago")
  activo         Boolean       @default(true)
  creadoEn       DateTime      @default(now()) @map("creado_en")
  actualizadoEn  DateTime      @updatedAt @map("actualizado_en")

  pedidos        Pedido[]
  facturas       Factura[]
  pagosV2        PagoV2[]
  guias          Guia[]  @relation("GuiaDestinatario")
  guiasRemitente Guia[]  @relation("GuiaRemitente")

  @@map("clientes")
}

model Pedido {
  id             Int          @id @default(autoincrement())
  clienteId      Int          @map("cliente_id")
  usuarioId      Int          @map("usuario_id")
  origen         String
  destino        String
  tipoCarga      String       @map("tipo_carga")
  tarifa         Decimal      @db.Decimal(10, 2)
  estado         EstadoPedido @default(ACTIVO)
  observaciones  String?
  fechaPedido    DateTime     @default(now()) @map("fecha_pedido")
  creadoEn       DateTime     @default(now()) @map("creado_en")
  actualizadoEn  DateTime     @updatedAt @map("actualizado_en")

  cliente        Cliente      @relation(fields: [clienteId], references: [id])
  usuario        Usuario      @relation(fields: [usuarioId], references: [id])
  facturas       Factura[]
  // NUEVO: relación con liquidaciones
  liquidaciones  LiquidacionPedido[]
  guias          Guia[]

  @@map("pedidos")
}

model Factura {
  id               Int           @id @default(autoincrement())
  pedidoId         Int?          @map("pedido_id")
  clienteId        Int           @map("cliente_id")
  usuarioId        Int           @map("usuario_id")
  serie            String        @default("F001")
  correlativo      Int
  numeroFactura    String        @unique @map("numero_factura")
  subtotal         Decimal       @db.Decimal(10, 2)
  porcentajeIgv    Decimal       @default(18) @map("porcentaje_igv") @db.Decimal(5, 2)
  igv              Decimal       @db.Decimal(10, 2)
  total            Decimal       @db.Decimal(10, 2)
  detraccion       Decimal?      @db.Decimal(10, 2)
  porcentajeDetraccion Decimal?  @map("porcentaje_detraccion") @db.Decimal(5, 2)
  montoDetraccion  Decimal?      @map("monto_detraccion") @db.Decimal(10, 2)
  tipoCredito      String?       @map("tipo_credito")
  diasCredito      Int?          @map("dias_credito")
  guiaReferencia   String?       @map("guia_referencia")
  peso             Decimal?      @db.Decimal(10, 2)
  detalle          String?
  estado           EstadoFactura @default(EMITIDA)
  estadoSunat      String?       @map("estado_sunat")
  xmlPath          String?       @map("xml_path")
  pdfPath          String?       @map("pdf_path")
  cdrPath          String?       @map("cdr_path")
  hashXml          String?       @map("hash_xml")
  fechaEmision     DateTime      @default(now()) @map("fecha_emision")
  fechaVencimiento DateTime      @map("fecha_vencimiento")
  observaciones    String?
  totalPagado      Decimal       @default(0) @map("total_pagado") @db.Decimal(10, 2)
  creadoEn         DateTime      @default(now()) @map("creado_en")
  actualizadoEn    DateTime      @updatedAt @map("actualizado_en")

  pedido         Pedido?         @relation(fields: [pedidoId], references: [id])
  cliente        Cliente         @relation(fields: [clienteId], references: [id])
  usuario        Usuario         @relation(fields: [usuarioId], references: [id])
  pagosV2        PagoV2[]
  lineas         FacturaDetalle[]
  guias          Guia[]

  @@map("facturas")
}

model FacturaDetalle {
  id             Int      @id @default(autoincrement())
  facturaId      Int      @map("factura_id")
  orden          Int      @default(0)
  cantidad       Decimal  @db.Decimal(10, 3)
  unidadMedida   String   @default("NIU") @map("unidad_medida")
  codigo         String?
  descripcion    String
  valorUnitario  Decimal  @map("valor_unitario") @db.Decimal(10, 2)
  importe        Decimal  @db.Decimal(10, 2)
  creadoEn       DateTime @default(now()) @map("creado_en")

  factura        Factura  @relation(fields: [facturaId], references: [id], onDelete: Cascade)

  @@map("factura_detalles")
}

model Caja {
  id              Int        @id @default(autoincrement())
  usuarioId       Int        @map("usuario_id")
  nombre          String?
  fecha           DateTime   @db.Date
  saldoApertura   Decimal    @default(0) @map("saldo_apertura") @db.Decimal(10, 2)
  saldoCierre     Decimal?   @map("saldo_cierre") @db.Decimal(10, 2)
  estado          EstadoCaja @default(ABIERTA)
  observaciones   String?
  // Cuenta de dinero de la que se retira el efectivo de apertura (genera un
  // movimiento de salida automático en esa cuenta). Nullable solo por
  // compatibilidad con cajas históricas; el flujo de apertura la exige.
  cuentaOrigenId  Int?       @map("cuenta_origen_id")
  // Cuenta destino donde se devuelve el saldo restante al cerrar la caja.
  // Si se establece, significa que ya se generó el movimiento de devolución.
  cuentaDestinoId Int?       @map("cuenta_destino_id")
  // Módulo Movimientos: egreso (categoría CAJA_CHICA) del que se abrió esta caja.
  // Un mismo egreso solo puede abrir una caja (@unique). Nullable por compatibilidad
  // con cajas históricas, que generaban su propio egreso identificado por referencia.
  movimientoCuentaId Int?    @unique @map("movimiento_cuenta_id")
  // Ingreso (devolución de saldo) generado automáticamente al cerrar esta caja
  // con cuenta destino. @unique porque cada cierre genera a lo más un ingreso.
  // Vía este vínculo (en vez de `referencia`) se identifica el ingreso como
  // "devolución de caja chica" — `referencia` queda libre para que el usuario
  // escriba el N° de operación bancario real de esa devolución.
  movimientoCierreId Int?    @unique @map("movimiento_cierre_id")
  aperturaEn      DateTime   @default(now()) @map("apertura_en")
  cierreEn        DateTime?  @map("cierre_en")
  creadoEn        DateTime   @default(now()) @map("creado_en")
  actualizadoEn   DateTime   @updatedAt @map("actualizado_en")

  usuario         Usuario       @relation(fields: [usuarioId], references: [id])
  cuentaOrigen    CuentaDinero? @relation("CajaOrigen", fields: [cuentaOrigenId], references: [id])
  cuentaDestino   CuentaDinero? @relation("CajaDestino", fields: [cuentaDestinoId], references: [id])
  movimientoCuenta MovimientoCuentaV2? @relation("CajaApertura", fields: [movimientoCuentaId], references: [id])
  movimientoCierre MovimientoCuentaV2? @relation("CajaCierre", fields: [movimientoCierreId], references: [id])
  movimientos     MovimientoCaja[]

  @@map("cajas")
}

model MovimientoCaja {
  id                 Int                @id @default(autoincrement())
  cajaId             Int                @map("caja_id")
  tipo               TipoMovimientoCaja
  monto              Decimal            @db.Decimal(10, 2)
  concepto           String
  // BUG 5 FIX: fecha editable y referencia externa
  fecha              DateTime?          @map("fecha")
  referencia         String?
  // MEJORA 2: anulación lógica (false = activo, true = anulado; default false)
  anulado            Boolean            @default(false)
  pagoId             Int?               @map("pago_id")
  gastoId            Int?               @map("gasto_id")
  // CHAT 9: vínculo con MovimientoCuentaV2 (nullable para compatibilidad histórica)
  movimientoCuentaId Int?               @map("movimiento_cuenta_id")
  creadoEn           DateTime           @default(now()) @map("creado_en")

  caja               Caja              @relation(fields: [cajaId], references: [id])
  movimientoCuenta   MovimientoCuentaV2? @relation("MovCajaCuenta", fields: [movimientoCuentaId], references: [id])

  @@map("movimientos_caja")
}

model LogActividad {
  id         Int      @id @default(autoincrement())
  usuarioId  Int      @map("usuario_id")
  accion     String
  modulo     String
  detalle    String?
  ip         String?
  fechaHora  DateTime @default(now()) @map("fecha_hora")

  usuario    Usuario  @relation(fields: [usuarioId], references: [id])

  @@index([fechaHora])
  @@map("log_actividad")
}

// ─── CONDUCTOR ────────────────────────────────────────────────────────────────
model Conductor {
  id                  Int      @id @default(autoincrement())
  nombre              String
  dni                 String   @unique
  licencia            String
  vencimientoLicencia DateTime @map("vencimiento_licencia")
  telefono            String?
  direccion           String?
  activo              Boolean  @default(true)
  observaciones       String?
  tractoPreferencia   String?  @map("tracto_preferencia")
  carretaPreferencia  String?  @map("carreta_preferencia")
  creadoEn            DateTime @default(now()) @map("creado_en")
  actualizadoEn       DateTime @updatedAt @map("actualizado_en")

  liquidaciones       Liquidacion[]
  combustibles        Combustible[]
  guias               Guia[]

  @@map("conductores")
}

// ─── VEHICULO ─────────────────────────────────────────────────────────────────
enum TipoVehiculo {
  TRACTO
  CARRETA
}

model Vehiculo {
  id                   Int          @id @default(autoincrement())
  placa                String       @unique
  tipo                 TipoVehiculo
  marca                String
  modelo               String
  anio                 Int
  soat                 String?
  vencimientoSoat      DateTime?    @map("vencimiento_soat")
  revisionTecnica      String?      @map("revision_tecnica")
  vencimientoRevision  DateTime?    @map("vencimiento_revision")
  ultimoMantenimiento  DateTime?    @map("ultimo_mantenimiento")
  proximoMantenimiento DateTime?    @map("proximo_mantenimiento")
  estado               String       @default("OPERATIVO")
  observaciones        String?
  activo               Boolean      @default(true)
  creadoEn             DateTime     @default(now()) @map("creado_en")
  actualizadoEn        DateTime     @updatedAt @map("actualizado_en")

  combustibles         Combustible[]
  guias                Guia[]

  @@map("vehiculos")
}

// ─── LIQUIDACION ──────────────────────────────────────────────────────────────
model Liquidacion {
  id             Int                 @id @default(autoincrement())
  conductorId    Int                 @map("conductor_id")
  placaTracto    String              @map("placa_tracto")
  placaCarreta   String?             @map("placa_carreta")
  montoEntregado Decimal             @map("monto_entregado") @db.Decimal(10, 2)
  reciboAnticipo String?             @map("recibo_anticipo")
  fecha          DateTime
  guiaReferencia String?             @map("guia_referencia")
  observaciones  String?
  toldo          Decimal?            @db.Decimal(10, 2)
  totalGastos    Decimal             @default(0) @map("total_gastos") @db.Decimal(10, 2)
  devolucion     Decimal             @default(0) @db.Decimal(10, 2)
  reintegro      Decimal             @default(0) @db.Decimal(10, 2)
  // Flujo: CREADA → PAGADA → RENDIDA → CERRADA
  // (legacy: PENDIENTE_RENDICION, PENDIENTE mapeados a CREADA en la lógica de servicio)
  estado         String              @default("CREADA")
  // Campos del nuevo flujo
  fechaPago      DateTime?           @map("fecha_pago")
  montoPagado    Decimal?            @map("monto_pagado") @db.Decimal(10, 2)
  fechaRendicion DateTime?           @map("fecha_rendicion")
  montoRendido   Decimal?            @map("monto_rendido") @db.Decimal(10, 2)
  fechaCierre    DateTime?           @map("fecha_cierre")
  montoDevolucion Decimal?           @map("monto_devolucion") @db.Decimal(10, 2)
  tipoAjuste     String?             @map("tipo_ajuste")
  creadoEn       DateTime            @default(now()) @map("creado_en")
  actualizadoEn  DateTime            @updatedAt @map("actualizado_en")

  conductor      Conductor           @relation(fields: [conductorId], references: [id])
  detalles       LiquidacionDetalle[]
  // NUEVO: pedidos relacionados
  pedidos        LiquidacionPedido[]
  // CHAT 9: movimientos de cuenta asociados a pagos de esta liquidación
  movimientosCuenta MovimientoCuentaV2[] @relation("LiquidacionPago")
  // P4: cargas de combustible asociadas a esta liquidación
  combustibles   Combustible[]

  @@map("liquidaciones")
}

enum CategoriaDetalle {
  PEAJE
  BALANZA
  VIATICO
  TOLDO
  OTROS
}

model LiquidacionDetalle {
  id             Int              @id @default(autoincrement())
  liquidacionId  Int              @map("liquidacion_id")
  categoria      CategoriaDetalle
  descripcion    String
  monto          Decimal          @db.Decimal(10, 2)

  liquidacion    Liquidacion      @relation(fields: [liquidacionId], references: [id], onDelete: Cascade)

  @@map("liquidacion_detalles")
}

// ─── NUEVO: PEDIDOS RELACIONADOS A LIQUIDACIÓN ────────────────────────────────
// Relación N:M explícita entre Liquidacion y Pedido.
// Restricción de negocio: un pedido solo puede estar en UNA liquidación activa
// (validado en el service, no solo aquí).
model LiquidacionPedido {
  id            Int         @id @default(autoincrement())
  liquidacionId Int         @map("liquidacion_id")
  pedidoId      Int         @map("pedido_id")
  creadoEn      DateTime    @default(now()) @map("creado_en")

  liquidacion   Liquidacion @relation(fields: [liquidacionId], references: [id], onDelete: Cascade)
  pedido        Pedido      @relation(fields: [pedidoId], references: [id])

  @@unique([liquidacionId, pedidoId])  // no duplicar mismo pedido en la misma liquidación
  @@map("liquidacion_pedidos")
}

// ─── COMBUSTIBLE ──────────────────────────────────────────────────────────────
model Combustible {
  id            Int       @id @default(autoincrement())
  vehiculoId    Int       @map("vehiculo_id")
  conductorId   Int?      @map("conductor_id")
  // P4: liquidación del conductor a la que se asocia esta carga (opcional)
  liquidacionId Int?      @map("liquidacion_id")
  fecha         DateTime
  galones       Decimal   @db.Decimal(10, 3)
  monto         Decimal   @db.Decimal(10, 2)
  kilometraje   Decimal?  @db.Decimal(10, 2)
  grifo         String?
  observaciones String?
  creadoEn      DateTime  @default(now()) @map("creado_en")
  actualizadoEn DateTime  @updatedAt @map("actualizado_en")

  // Módulo Movimientos: egreso (categoría COMBUSTIBLE) del que se descuenta esta
  // carga. Nullable por compatibilidad con cargas históricas (creadas antes de
  // este vínculo, que generaban su propio egreso identificado por referencia).
  movimientoCuentaId Int? @map("movimiento_cuenta_id")

  vehiculo      Vehiculo     @relation(fields: [vehiculoId], references: [id])
  conductor     Conductor?   @relation(fields: [conductorId], references: [id])
  liquidacion   Liquidacion? @relation(fields: [liquidacionId], references: [id])
  movimientoCuenta MovimientoCuentaV2? @relation(fields: [movimientoCuentaId], references: [id])

  @@map("combustible")
}

// ─── CONFIGURACIÓN: PARÁMETROS GENERALES ─────────────────────────────────────
model Configuracion {
  id            Int      @id @default(autoincrement())
  clave         String   @unique
  valor         String
  tipo          String   @default("texto")
  categoria     String   @default("general")
  etiqueta      String
  descripcion   String?
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  @@map("configuraciones")
}

// ─── SERIES DE FACTURACIÓN ────────────────────────────────────────────────────
model SerieFacturacion {
  id                Int      @id @default(autoincrement())
  serie             String   @unique
  tipoDocumento     String   @default("FACTURA") @map("tipo_documento")
  correlativoActual Int      @default(1) @map("correlativo_actual")
  correlativoInicial Int     @default(1) @map("correlativo_inicial")
  activo            Boolean  @default(true)
  descripcion       String?
  creadoEn          DateTime @default(now()) @map("creado_en")
  actualizadoEn     DateTime @updatedAt @map("actualizado_en")

  @@map("series_facturacion")
}

// ─── TABLA MAESTRA GENÉRICA ───────────────────────────────────────────────────
model TablaMaestra {
  id            Int      @id @default(autoincrement())
  tipo          String
  codigo        String
  nombre        String
  descripcion   String?
  extra         String?
  activo        Boolean  @default(true)
  orden         Int      @default(0)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  @@unique([tipo, codigo])
  @@map("tablas_maestras")
}

// ─── CONFIGURACIÓN DE ALERTAS ─────────────────────────────────────────────────
model ConfiguracionAlerta {
  id               Int      @id @default(autoincrement())
  clave            String   @unique
  etiqueta         String
  diasAnticipacion Int      @default(30) @map("dias_anticipacion")
  activo           Boolean  @default(true)
  color            String   @default("yellow")
  nivel            String   @default("warning")
  creadoEn         DateTime @default(now()) @map("creado_en")
  actualizadoEn    DateTime @updatedAt @map("actualizado_en")

  @@map("configuracion_alertas")
}

// ─── TIPOS DE VEHÍCULO ────────────────────────────────────────────────────────
model TipoVehiculoConfig {
  id            Int      @id @default(autoincrement())
  codigo        String   @unique
  nombre        String
  descripcion   String?
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  @@map("tipos_vehiculo_config")
}

// ─── PERMISOS DE MÓDULOS ──────────────────────────────────────────────────────
model PermisoModulo {
  id            Int      @id @default(autoincrement())
  usuarioId     Int      @map("usuario_id")
  moduloKey     String   @map("modulo_key")
  habilitado    Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, moduloKey])
  @@map("permisos_modulos")
}

// ─── PERMISOS DE ACCIONES ESPECIALES ────────────────────────────────────────
model PermisoAccion {
  id            Int      @id @default(autoincrement())
  usuarioId     Int      @map("usuario_id")
  accionKey     String   @map("accion_key")
  habilitado    Boolean  @default(false)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, accionKey])
  @@map("permisos_acciones")
}

// ─── MONEDAS ──────────────────────────────────────────────────────────────────
model Moneda {
  id            Int      @id @default(autoincrement())
  codigo        String   @unique
  nombre        String
  simbolo       String
  esPorDefecto  Boolean  @default(false) @map("es_por_defecto")
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  cuentas           CuentaDinero[]
  movimientos       MovimientoCuentaV2[]
  pagosV2           PagoV2[]

  @@map("monedas")
}

// ─── TIPOS DE PAGO ────────────────────────────────────────────────────────────
model TipoPago {
  id            Int      @id @default(autoincrement())
  codigo        String   @unique
  nombre        String
  descripcion   String?
  orden         Int      @default(0)
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  movimientos   MovimientoCuentaV2[]
  pagosV2       PagoV2[]

  @@map("tipos_pago")
}

// ─── CUENTAS DE DINERO ────────────────────────────────────────────────────────
model CuentaDinero {
  id            Int      @id @default(autoincrement())
  nombre        String
  tipoCuenta    String   @map("tipo_cuenta")
  monedaId      Int      @map("moneda_id")
  saldoInicial  Decimal  @default(0) @map("saldo_inicial") @db.Decimal(12, 2)
  saldoActual   Decimal  @default(0) @map("saldo_actual") @db.Decimal(12, 2)
  descripcion   String?
  banco         String?
  numeroCuenta  String?  @map("numero_cuenta")
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  moneda        Moneda   @relation(fields: [monedaId], references: [id])
  movimientos   MovimientoCuentaV2[] @relation("CuentaOrigen")
  movimientosDestino MovimientoCuentaV2[] @relation("CuentaDestino")
  // Cajas abiertas tomando esta cuenta como origen de los fondos de apertura
  cajasOrigen   Caja[] @relation("CajaOrigen")
  // Cajas cerradas que devolvieron su saldo a esta cuenta
  cajasDestino  Caja[] @relation("CajaDestino")

  @@map("cuentas_dinero")
}

// ─── MOVIMIENTOS DE CUENTA V2 ─────────────────────────────────────────────────
model MovimientoCuentaV2 {
  id               Int      @id @default(autoincrement())
  cuentaId         Int      @map("cuenta_id")
  tipo             String   // INGRESO | EGRESO | TRANSFERENCIA
  monto            Decimal  @db.Decimal(12, 2)
  monedaId         Int      @map("moneda_id")
  tipoPagoId       Int?     @map("tipo_pago_id")
  concepto         String
  referencia       String?
  cuentaDestinoId  Int?     @map("cuenta_destino_id")
  usuarioId        Int      @map("usuario_id")
  // CHAT 9: vínculo directo con liquidación pagada (nullable para compatibilidad)
  liquidacionId    Int?     @map("liquidacion_id")
  // P7: anulación lógica (false = activo, true = anulado; default false)
  anulado          Boolean  @default(false)
  // Módulo Movimientos: distingue movimientos creados a mano de los importados de un Excel bancario
  origen           String   @default("MANUAL") // MANUAL | EXCEL
  // Módulo Movimientos: nota libre solo para egresos — describe en qué se usó el
  // gasto, independiente de `referencia` (N° de operación bancario, no se toca).
  notaEgreso       String?  @map("nota_egreso")
  // Módulo Movimientos: categoría del egreso (COMBUSTIBLE | REPUESTOS | CAJA_CHICA |
  // PLANILLA | OTROS). Solo aplica a egresos. COMBUSTIBLE y CAJA_CHICA determinan
  // que este egreso pueda ser consumido desde esos módulos en vez de que ellos
  // generen su propio movimiento financiero.
  categoriaEgreso  String?  @map("categoria_egreso")
  fecha            DateTime @default(now())
  creadoEn         DateTime @default(now()) @map("creado_en")

  cuenta           CuentaDinero @relation("CuentaOrigen", fields: [cuentaId], references: [id])
  moneda           Moneda       @relation(fields: [monedaId], references: [id])
  tipoPago         TipoPago?    @relation(fields: [tipoPagoId], references: [id])
  cuentaDestino    CuentaDinero? @relation("CuentaDestino", fields: [cuentaDestinoId], references: [id])
  usuario          Usuario      @relation(fields: [usuarioId], references: [id])
  liquidacion      Liquidacion? @relation("LiquidacionPago", fields: [liquidacionId], references: [id])
  // Back-relation: movimientos de caja que apuntan a este movimiento de cuenta
  movimientosCaja  MovimientoCaja[] @relation("MovCajaCuenta")
  // Módulo Movimientos: cobranza vinculada a este movimiento (solo si tipo = INGRESO)
  cobranza         PagoV2?
  // Cargas de combustible que descuentan de este egreso (categoría COMBUSTIBLE)
  combustibles     Combustible[]
  // Caja abierta a partir de este egreso (categoría CAJA_CHICA)
  cajaApertura     Caja? @relation("CajaApertura")
  // Caja cuyo cierre generó este ingreso (devolución de saldo)
  cajaCierre       Caja? @relation("CajaCierre")

  @@map("movimientos_cuenta_v2")
}

// ─── GUÍAS DE REMISIÓN (SUNAT GRE) ────────────────────────────────────────────
// Portado de MONKSAAS (versión single-tenant: sin empresaId ni ventas/productos).
model Guia {
  id                       Int       @id @default(autoincrement())
  numero                   String    @unique
  serie                    String?
  // Origen del traslado: pedido de transporte (equivale a la Venta en el
  // sistema original). Opcional — la guía puede emitirse suelta.
  pedidoId                 Int?      @map("pedido_id")
  facturaId                Int?      @map("factura_id")
  // En REMITENTE, clienteId es el destinatario de la mercadería. En
  // TRANSPORTISTA sigue siendo el destinatario, pero además se exige
  // remitenteId: ninguna de las dos partes es quien emite la guía.
  // Opcional: ingreso libre (clienteNombre + clienteNumDoc) cuando el
  // destinatario no es un Cliente registrado. Exactamente uno de los dos
  // debe estar presente (ver guias.service.ts).
  clienteId                Int?      @map("cliente_id")
  clienteNombre            String?   @map("cliente_nombre")
  clienteNumDoc            String?   @map("cliente_num_doc")
  remitenteId              Int?      @map("remitente_id")
  usuarioId                Int       @map("usuario_id")
  fechaEmision             DateTime  @default(now()) @map("fecha_emision")
  estado                   String    @default("EMITIDA")
  // Catálogo SUNAT 01 — tipo de comprobante: 09 Guía Remitente, 31 Guía
  // Transportista (la empresa emisora es la transportista, no remitente ni
  // destinataria; exige datos de ambas partes y de vehículo/conductor).
  tipoGuia                 String    @default("REMITENTE") @map("tipo_guia")
  // SUNAT: catálogo 20 (motivo) y 18 (modalidad 01=público / 02=privado)
  motivoTraslado           String    @default("01") @map("motivo_traslado")
  modalidadTransporte      String    @default("02") @map("modalidad_transporte")
  fechaInicioTraslado      DateTime? @map("fecha_inicio_traslado")
  ubigeoOrigen             String?   @map("ubigeo_origen")
  direccionPartida         String?   @map("direccion_partida")
  ubigeoDestino            String?   @map("ubigeo_destino")
  direccionEntrega         String?   @map("direccion_entrega")
  // Modalidad pública — datos del transportista tercero
  rucTransportista         String?   @map("ruc_transportista")
  razonSocialTransportista String?   @map("razon_social_transportista")
  numRegistroMTC           String?   @map("num_registro_mtc")
  placaTransportista       String?   @map("placa_transportista")
  // Modalidad privada — conductor y vehículo propios
  conductorId              Int?      @map("conductor_id")
  vehiculoId               Int?      @map("vehiculo_id")
  conductorNombre          String?   @map("conductor_nombre")
  conductorDni             String?   @map("conductor_dni")
  conductorLicencia        String?   @map("conductor_licencia")
  pesoTotal                Decimal?  @map("peso_total") @db.Decimal(10, 2)
  observaciones            String?
  // ─── Resultado del envío a SUNAT (GRE es asíncrono: el envío inicial solo
  // devuelve un ticket; xmlPath/cdrPath quedan null hasta que el job de
  // polling confirma "procesado: true") ────────────────────────────────────
  estadoSunat              String?   @map("estado_sunat")
  motivoRechazoSunat       String?   @map("motivo_rechazo_sunat")
  ticketSunat              String?   @map("ticket_sunat")
  xmlPath                  String?   @map("xml_path")
  pdfPath                  String?   @map("pdf_path")
  cdrPath                  String?   @map("cdr_path")
  hashXml                  String?   @map("hash_xml")
  anulado                  Boolean   @default(false)
  creadoEn                 DateTime  @default(now()) @map("creado_en")
  actualizadoEn            DateTime  @updatedAt @map("actualizado_en")

  pedido    Pedido?    @relation(fields: [pedidoId], references: [id])
  factura   Factura?   @relation(fields: [facturaId], references: [id])
  cliente   Cliente?   @relation("GuiaDestinatario", fields: [clienteId], references: [id])
  remitente Cliente?   @relation("GuiaRemitente", fields: [remitenteId], references: [id])
  usuario   Usuario    @relation(fields: [usuarioId], references: [id])
  conductor Conductor? @relation(fields: [conductorId], references: [id])
  vehiculo  Vehiculo?  @relation(fields: [vehiculoId], references: [id])

  detalles                   GuiaDetalle[]
  transportistasAdicionales  GuiaTransportistaAdicional[]

  @@map("guias")
}

model GuiaDetalle {
  id           Int     @id @default(autoincrement())
  guiaId       Int     @map("guia_id")
  descripcion  String
  cantidad     Decimal @db.Decimal(12, 3)
  unidadMedida String  @default("NIU") @map("unidad_medida")

  guia Guia @relation(fields: [guiaId], references: [id], onDelete: Cascade)

  @@map("guia_detalles")
}

// Placas/MTC adicionales cuando Guia.modalidadTransporte = '01' (transporte público)
model GuiaTransportistaAdicional {
  id             Int    @id @default(autoincrement())
  guiaId         Int    @map("guia_id")
  placa          String
  numRegistroMTC String @map("num_registro_mtc")

  guia Guia @relation(fields: [guiaId], references: [id], onDelete: Cascade)

  @@map("guia_transportistas_adicionales")
}

// ─── PAGOS V2 ─────────────────────────────────────────────────────────────────
// Módulo Movimientos: registra la vinculación de cobranza de un ingreso importado
// (cliente + factura, o cliente + observación libre si no aplica a ninguna factura)
model PagoV2 {
  id                 Int      @id @default(autoincrement())
  facturaId          Int?     @map("factura_id")
  clienteId          Int?     @map("cliente_id")
  usuarioId          Int      @map("usuario_id")
  monto              Decimal  @db.Decimal(12, 2)
  monedaId           Int      @map("moneda_id")
  tipoPagoId         Int?     @map("tipo_pago_id")
  referencia         String?
  observaciones      String?
  fechaPago          DateTime @default(now()) @map("fecha_pago")
  // Vínculo con el movimiento de cuenta (ingreso) que esta cobranza explica
  movimientoCuentaId Int?     @unique @map("movimiento_cuenta_id")
  // Anulación lógica — no revierte el movimiento de cuenta, solo desvincula la cobranza
  anulado            Boolean  @default(false)
  motivoAnulacion    String?  @map("motivo_anulacion")
  anuladoEn          DateTime? @map("anulado_en")
  creadoEn           DateTime @default(now()) @map("creado_en")

  factura            Factura?  @relation(fields: [facturaId], references: [id])
  cliente            Cliente?  @relation(fields: [clienteId], references: [id])
  moneda             Moneda   @relation(fields: [monedaId], references: [id])
  tipoPago           TipoPago? @relation(fields: [tipoPagoId], references: [id])
  usuario            Usuario  @relation(fields: [usuarioId], references: [id])
  movimientoCuenta   MovimientoCuentaV2? @relation(fields: [movimientoCuentaId], references: [id])

  @@map("pagos_v2")
}
