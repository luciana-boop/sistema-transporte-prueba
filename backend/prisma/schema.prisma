// ─── CUENTAS DE DINERO ────────────────────────────────────────────────────────
model CuentaDinero {
  id               Int      @id @default(autoincrement())
  nombre           String
  tipoCuenta       String   @map("tipo_cuenta")
  monedaId         Int      @map("moneda_id")
  saldoInicial     Decimal  @default(0) @map("saldo_inicial") @db.Decimal(12, 2)
  saldoActual      Decimal  @default(0) @map("saldo_actual") @db.Decimal(12, 2)
  descripcion      String?
  banco            String?
  numeroCuenta     String?  @map("numero_cuenta")
  activo           Boolean  @default(true)
  creadoEn         DateTime @default(now()) @map("creado_en")
  actualizadoEn    DateTime @updatedAt @map("actualizado_en")
  creadoPorId      Int?     @map("creado_por_id")
  actualizadoPorId Int?     @map("actualizado_por_id")

  moneda             Moneda               @relation(fields: [monedaId], references: [id])
  movimientos        MovimientoCuentaV2[] @relation("CuentaOrigen")
  movimientosDestino MovimientoCuentaV2[] @relation("CuentaDestino")
  // Cajas abiertas tomando esta cuenta como origen de los fondos de apertura
  cajasOrigen        Caja[]               @relation("CajaOrigen")
  // Cajas cerradas que devolvieron su saldo a esta cuenta
  cajasDestino       Caja[]               @relation("CajaDestino")
  creadoPor          Usuario?             @relation("CuentaDineroCreadoPor", fields: [creadoPorId], references: [id])
  actualizadoPor     Usuario?             @relation("CuentaDineroActualizadoPor", fields: [actualizadoPorId], references: [id])

  @@map("cuentas_dinero")
}

// ─── MOVIMIENTOS DE CUENTA V2 ─────────────────────────────────────────────────
model MovimientoCuentaV2 {
  id               Int       @id @default(autoincrement())
  cuentaId         Int       @map("cuenta_id")
  tipo             String // INGRESO | EGRESO | TRANSFERENCIA
  monto            Decimal   @db.Decimal(12, 2)
  monedaId         Int       @map("moneda_id")
  tipoPagoId       Int?      @map("tipo_pago_id")
  concepto         String
  referencia       String?
  cuentaDestinoId  Int?      @map("cuenta_destino_id")
  usuarioId        Int       @map("usuario_id")
  // CHAT 9: vínculo directo con liquidación pagada (nullable para compatibilidad)
  liquidacionId    Int?      @map("liquidacion_id")
  // P7: anulación lógica (false = activo, true = anulado; default false)
  anulado          Boolean   @default(false)
  // Módulo Movimientos: distingue movimientos creados a mano de los importados de un Excel bancario
  origen           String    @default("MANUAL") // MANUAL | EXCEL
  // Módulo Movimientos: nota libre solo para egresos — describe en qué se usó el
  // gasto, independiente de `referencia` (N° de operación bancario, no se toca).
  notaEgreso       String?   @map("nota_egreso")
  // Módulo Movimientos: categoría del egreso (COMBUSTIBLE | MANTENIMIENTO | CAJA_CHICA |
  // PLANILLA | OTROS). Solo aplica a egresos. COMBUSTIBLE y CAJA_CHICA determinan
  // que este egreso pueda ser consumido desde esos módulos en vez de que ellos
  // generen su propio movimiento financiero. MANTENIMIENTO se consume desde el
  // módulo Mantenimiento (ver MantenimientoDetalle).
  categoriaEgreso  String?   @map("categoria_egreso")
  // Módulo Movimientos: categoría del ingreso (PAGO_FACTURA | CAJA_CHICA | LIQUIDACION |
  // OTRO). Solo aplica a ingresos. PAGO_FACTURA crea un PagoV2 "sin aplicar" que se
  // reparte luego entre facturas del cliente desde el módulo Cobranza.
  categoriaIngreso String?   @map("categoria_ingreso")
  // Módulo Movimientos: observación libre para ingresos cuyo categoriaIngreso no es
  // PAGO_FACTURA (no requieren cliente/factura, solo un detalle de texto).
  notaIngreso      String?   @map("nota_ingreso")
  fecha            DateTime  @default(now())
  creadoEn         DateTime  @default(now()) @map("creado_en")
  actualizadoEn    DateTime? @updatedAt @map("actualizado_en")
  creadoPorId      Int?      @map("creado_por_id")
  actualizadoPorId Int?      @map("actualizado_por_id")

  cuenta          CuentaDinero          @relation("CuentaOrigen", fields: [cuentaId], references: [id])
  moneda          Moneda                @relation(fields: [monedaId], references: [id])
  tipoPago        TipoPago?             @relation(fields: [tipoPagoId], references: [id])
  cuentaDestino   CuentaDinero?         @relation("CuentaDestino", fields: [cuentaDestinoId], references: [id])
  usuario         Usuario               @relation(fields: [usuarioId], references: [id])
  liquidacion     Liquidacion?          @relation("LiquidacionPago", fields: [liquidacionId], references: [id])
  // Back-relation: movimientos de caja que apuntan a este movimiento de cuenta
  movimientosCaja MovimientoCaja[]      @relation("MovCajaCuenta")
  // Módulo Movimientos: cobranza vinculada a este movimiento (solo si tipo = INGRESO)
  cobranza        PagoV2?
  // Cargas de combustible que descuentan de este egreso (categoría COMBUSTIBLE)
  combustibles    Combustible[]
  // Caja abierta a partir de este egreso (categoría CAJA_CHICA)
  cajaApertura    Caja?                 @relation("CajaApertura")
  // Caja cuyo cierre generó este ingreso (devolución de saldo)
  cajaCierre      Caja?                 @relation("CajaCierre")
  // Módulo Mantenimiento: detalle de vehículo/conductor/motivo de este egreso (categoría MANTENIMIENTO)
  mantenimiento   MantenimientoDetalle?
  creadoPor       Usuario?              @relation("MovimientoCuentaV2CreadoPor", fields: [creadoPorId], references: [id])
  actualizadoPor  Usuario?              @relation("MovimientoCuentaV2ActualizadoPor", fields: [actualizadoPorId], references: [id])

  @@map("movimientos_cuenta_v2")
}

// ─── GUÍAS DE REMISIÓN (SUNAT GRE) ────────────────────────────────────────────
// Portado de MONKSAAS (versión single-tenant: sin empresaId ni ventas/productos).
model Guia {
  id                       Int       @id @default(autoincrement())
  numero                   String    @unique
  serie                    String?
  // Origen del traslado: pedido de transporte (equivale a la Venta en el
  // sistema original). Opcional — la guía puede emitirse suelta.
  pedidoId                 Int?      @map("pedido_id")
  facturaId                Int?      @map("factura_id")
  // En REMITENTE, clienteId es el destinatario de la mercadería. En
  // TRANSPORTISTA sigue siendo el destinatario, pero además se exige
  // remitenteId: ninguna de las dos partes es quien emite la guía.
  // Opcional: ingreso libre (clienteNombre + clienteNumDoc) cuando el
  // destinatario no es un Cliente registrado. Exactamente uno de los dos
  // debe estar presente (ver guias.service.ts).
  clienteId                Int?      @map("cliente_id")
  clienteNombre            String?   @map("cliente_nombre")
  clienteNumDoc            String?   @map("cliente_num_doc")
  remitenteId              Int?      @map("remitente_id")
  usuarioId                Int       @map("usuario_id")
  fechaEmision             DateTime  @default(now()) @map("fecha_emision")
  estado                   String    @default("EMITIDA")
  // Catálogo SUNAT 01 — tipo de comprobante: 09 Guía Remitente, 31 Guía
  // Transportista (la empresa emisora es la transportista, no remitente ni
  // destinataria; exige datos de ambas partes y de vehículo/conductor).
  tipoGuia                 String    @default("REMITENTE") @map("tipo_guia")
  // SUNAT: catálogo 20 (motivo) y 18 (modalidad 01=público / 02=privado)
  motivoTraslado           String    @default("01") @map("motivo_traslado")
  modalidadTransporte      String    @default("02") @map("modalidad_transporte")
  fechaInicioTraslado      DateTime? @map("fecha_inicio_traslado")
  ubigeoOrigen             String?   @map("ubigeo_origen")
  direccionPartida         String?   @map("direccion_partida")
  ubigeoDestino            String?   @map("ubigeo_destino")
  direccionEntrega         String?   @map("direccion_entrega")
  // Modalidad pública — datos del transportista tercero
  rucTransportista         String?   @map("ruc_transportista")
  razonSocialTransportista String?   @map("razon_social_transportista")
  numRegistroMTC           String?   @map("num_registro_mtc")
  placaTransportista       String?   @map("placa_transportista")
  // Modalidad privada — conductor y vehículo propios (tracto + carreta opcional)
  conductorId              Int?      @map("conductor_id")
  vehiculoId               Int?      @map("vehiculo_id")
  vehiculoCarretaId        Int?      @map("vehiculo_carreta_id")
  conductorNombre          String?   @map("conductor_nombre")
  conductorDni             String?   @map("conductor_dni")
  conductorLicencia        String?   @map("conductor_licencia")
  pesoTotal                Decimal?  @map("peso_total") @db.Decimal(10, 2)
  observaciones            String?
  // Documento relacionado (catálogo SUNAT 61) — obligatorio "cuando corresponda"
  // en Guía Transportista: referencia a la Guía de Remisión Remitente del
  // remitente (código 09) o, si el remitente no la emite, al comprobante de
  // pago que sustenta el traslado (01 Factura / 03 Boleta). El remitente es
  // un tercero externo a este sistema — se ingresa a mano, no hay relación
  // de base de datos.
  docRelTipo               String?   @map("doc_rel_tipo")
  docRelSerie              String?   @map("doc_rel_serie")
  docRelNumero             String?   @map("doc_rel_numero")
  docRelRucEmisor          String?   @map("doc_rel_ruc_emisor")
  // ─── Resultado del envío a SUNAT (GRE es asíncrono: el envío inicial solo
  // devuelve un ticket; xmlPath/cdrPath quedan null hasta que el job de
  // polling confirma "procesado: true") ────────────────────────────────────
  estadoSunat              String?   @map("estado_sunat")
  motivoRechazoSunat       String?   @map("motivo_rechazo_sunat")
  ticketSunat              String?   @map("ticket_sunat")
  xmlPath                  String?   @map("xml_path")
  pdfPath                  String?   @map("pdf_path")
  cdrPath                  String?   @map("cdr_path")
  hashXml                  String?   @map("hash_xml")
  anulado                  Boolean   @default(false)
  creadoEn                 DateTime  @default(now()) @map("creado_en")
  actualizadoEn            DateTime  @updatedAt @map("actualizado_en")
  creadoPorId              Int?      @map("creado_por_id")
  actualizadoPorId         Int?      @map("actualizado_por_id")

  pedido          Pedido?    @relation(fields: [pedidoId], references: [id])
  factura         Factura?   @relation(fields: [facturaId], references: [id])
  cliente         Cliente?   @relation("GuiaDestinatario", fields: [clienteId], references: [id])
  remitente       Cliente?   @relation("GuiaRemitente", fields: [remitenteId], references: [id])
  usuario         Usuario    @relation(fields: [usuarioId], references: [id])
  conductor       Conductor? @relation(fields: [conductorId], references: [id])
  vehiculo        Vehiculo?  @relation(fields: [vehiculoId], references: [id])
  vehiculoCarreta Vehiculo?  @relation("GuiaVehiculoCarreta", fields: [vehiculoCarretaId], references: [id])
  creadoPor       Usuario?   @relation("GuiaCreadoPor", fields: [creadoPorId], references: [id])
  actualizadoPor  Usuario?   @relation("GuiaActualizadoPor", fields: [actualizadoPorId], references: [id])

  detalles                  GuiaDetalle[]
  transportistasAdicionales GuiaTransportistaAdicional[]

  @@map("guias")
}

model GuiaDetalle {
  id           Int     @id @default(autoincrement())
  guiaId       Int     @map("guia_id")
  descripcion  String
  cantidad     Decimal @db.Decimal(12, 3)
  unidadMedida String  @default("NIU") @map("unidad_medida")

  guia Guia @relation(fields: [guiaId], references: [id], onDelete: Cascade)

  @@map("guia_detalles")
}

// Placas/MTC adicionales cuando Guia.modalidadTransporte = '01' (transporte público)
model GuiaTransportistaAdicional {
  id             Int    @id @default(autoincrement())
  guiaId         Int    @map("guia_id")
  placa          String
  numRegistroMTC String @map("num_registro_mtc")

  guia Guia @relation(fields: [guiaId], references: [id], onDelete: Cascade)

  @@map("guia_transportistas_adicionales")
}

// ─── PAGOS V2 ─────────────────────────────────────────────────────────────────
// Módulo Cobranza: registra el pago de un ingreso (cliente + factura(s), o
// cliente + observación libre si no aplica a ninguna factura). `facturaId` se
// conserva solo por compatibilidad con pagos históricos 1:1 — el flujo nuevo
// reparte el pago entre una o más facturas vía PagoV2AplicacionFactura.
model PagoV2 {
  id                 Int       @id @default(autoincrement())
  facturaId          Int?      @map("factura_id")
  clienteId          Int?      @map("cliente_id")
  usuarioId          Int       @map("usuario_id")
  monto              Decimal   @db.Decimal(12, 2)
  monedaId           Int       @map("moneda_id")
  tipoPagoId         Int?      @map("tipo_pago_id")
  referencia         String?
  observaciones      String?
  fechaPago          DateTime  @default(now()) @map("fecha_pago")
  // Vínculo con el movimiento de cuenta (ingreso) que esta cobranza explica
  movimientoCuentaId Int?      @unique @map("movimiento_cuenta_id")
  // Anulación lógica — no revierte el movimiento de cuenta, solo desvincula la cobranza
  anulado            Boolean   @default(false)
  motivoAnulacion    String?   @map("motivo_anulacion")
  anuladoEn          DateTime? @map("anulado_en")
  creadoEn           DateTime  @default(now()) @map("creado_en")
  actualizadoEn      DateTime? @updatedAt @map("actualizado_en")
  creadoPorId        Int?      @map("creado_por_id")
  actualizadoPorId   Int?      @map("actualizado_por_id")

  factura          Factura?                  @relation(fields: [facturaId], references: [id])
  cliente          Cliente?                  @relation(fields: [clienteId], references: [id])
  moneda           Moneda                    @relation(fields: [monedaId], references: [id])
  tipoPago         TipoPago?                 @relation(fields: [tipoPagoId], references: [id])
  usuario          Usuario                   @relation(fields: [usuarioId], references: [id])
  movimientoCuenta MovimientoCuentaV2?       @relation(fields: [movimientoCuentaId], references: [id])
  aplicaciones     PagoV2AplicacionFactura[]
  creadoPor        Usuario?                  @relation("PagoV2CreadoPor", fields: [creadoPorId], references: [id])
  actualizadoPor   Usuario?                  @relation("PagoV2ActualizadoPor", fields: [actualizadoPorId], references: [id])

  @@map("pagos_v2")
}

// ─── MÓDULO COBRANZA: APLICACIÓN DE UN PAGO A UNA O VARIAS FACTURAS ──────────
model PagoV2AplicacionFactura {
  id          Int      @id @default(autoincrement())
  pagoId      Int      @map("pago_id")
  facturaId   Int      @map("factura_id")
  monto       Decimal  @db.Decimal(12, 2)
  creadoEn    DateTime @default(now()) @map("creado_en")
  creadoPorId Int?     @map("creado_por_id")

  pago      PagoV2   @relation(fields: [pagoId], references: [id], onDelete: Cascade)
  factura   Factura  @relation(fields: [facturaId], references: [id])
  creadoPor Usuario? @relation("AplicacionFacturaCreadoPor", fields: [creadoPorId], references: [id])

  @@unique([pagoId, facturaId])
  @@map("pago_v2_aplicaciones_factura")
}

// ─── MÓDULO MANTENIMIENTO: RELACIÓN DE UN EGRESO A VEHÍCULO/CONDUCTOR/MOTIVO ─
// Un egreso (MovimientoCuentaV2, categoriaEgreso = MANTENIMIENTO) empieza "por
// relacionar"; al completarse este registro pasa a "relacionado". El motivo es
// configurable vía TablaMaestra (tipo = 'motivo_mantenimiento').
model MantenimientoDetalle {
  id                 Int      @id @default(autoincrement())
  movimientoCuentaId Int      @unique @map("movimiento_cuenta_id")
  vehiculoId         Int      @map("vehiculo_id")
  conductorId        Int?     @map("conductor_id")
  motivoCodigo       String   @map("motivo_codigo")
  descripcion        String?
  creadoEn           DateTime @default(now()) @map("creado_en")
  creadoPorId        Int?     @map("creado_por_id")
  actualizadoEn      DateTime @updatedAt @map("actualizado_en")
  actualizadoPorId   Int?     @map("actualizado_por_id")

  movimientoCuenta MovimientoCuentaV2 @relation(fields: [movimientoCuentaId], references: [id])
  vehiculo         Vehiculo           @relation(fields: [vehiculoId], references: [id])
  conductor        Conductor?         @relation(fields: [conductorId], references: [id])
  creadoPor        Usuario?           @relation("MantenimientoCreadoPor", fields: [creadoPorId], references: [id])
  actualizadoPor   Usuario?           @relation("MantenimientoActualizadoPor", fields: [actualizadoPorId], references: [id])

  @@map("mantenimiento_detalles")
}
