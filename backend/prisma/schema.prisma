// FILE: prisma/schema.prisma
// CAMBIO: Agrega modelo LiquidacionPedido para la relación N:M entre
// Liquidacion y Pedido. El resto del schema no se modifica.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Rol {
  ADMIN
  SECRETARIO
}

enum EstadoPedido {
  ACTIVO
  FACTURADO
  ANULADO
}

enum EstadoFactura {
  EMITIDA
  PAGADA
  PENDIENTE
  PARCIAL
  ANULADA
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  TARJETA
  CHEQUE
}

enum EstadoCaja {
  ABIERTA
  CERRADA
}

enum TipoMovimientoCaja {
  INGRESO
  EGRESO
}

enum TipoGasto {
  COMBUSTIBLE
  VIATICOS
  PEAJE
  MANTENIMIENTO
  OTROS
}

enum CondicionPago {
  CONTADO
  CREDITO_15
  CREDITO_30
  CREDITO_60
}

// ─── MODELOS ─────────────────────────────────────────────────────────────────

model Usuario {
  id             Int      @id @default(autoincrement())
  nombre         String
  email          String   @unique
  passwordHash   String   @map("password_hash")
  rol            Rol      @default(SECRETARIO)
  activo         Boolean  @default(true)
  ultimoAcceso   DateTime? @map("ultimo_acceso")
  creadoEn       DateTime @default(now()) @map("creado_en")
  actualizadoEn  DateTime @updatedAt @map("actualizado_en")

  pedidos        Pedido[]
  facturas       Factura[]
  pagos          Pago[]
  cajas          Caja[]
  gastos         Gasto[]
  logs           LogActividad[]

  permisosModulos  PermisoModulo[]
  permisosAcciones PermisoAccion[]
  movimientosCuentaV2 MovimientoCuentaV2[]
  pagosV2          PagoV2[]

  @@map("usuarios")
}

model Cliente {
  id             Int           @id @default(autoincrement())
  razonSocial    String        @map("razon_social")
  ruc            String        @unique
  direccion      String
  telefono       String?
  email          String?
  condicionPago  CondicionPago @default(CONTADO) @map("condicion_pago")
  activo         Boolean       @default(true)
  creadoEn       DateTime      @default(now()) @map("creado_en")
  actualizadoEn  DateTime      @updatedAt @map("actualizado_en")

  pedidos        Pedido[]
  facturas       Factura[]
  pagos          Pago[]

  @@map("clientes")
}

model Pedido {
  id             Int          @id @default(autoincrement())
  clienteId      Int          @map("cliente_id")
  usuarioId      Int          @map("usuario_id")
  origen         String
  destino        String
  tipoCarga      String       @map("tipo_carga")
  tarifa         Decimal      @db.Decimal(10, 2)
  estado         EstadoPedido @default(ACTIVO)
  observaciones  String?
  fechaPedido    DateTime     @default(now()) @map("fecha_pedido")
  creadoEn       DateTime     @default(now()) @map("creado_en")
  actualizadoEn  DateTime     @updatedAt @map("actualizado_en")

  cliente        Cliente      @relation(fields: [clienteId], references: [id])
  usuario        Usuario      @relation(fields: [usuarioId], references: [id])
  facturas       Factura[]
  gastos         Gasto[]
  // NUEVO: relación con liquidaciones
  liquidaciones  LiquidacionPedido[]

  @@map("pedidos")
}

model Factura {
  id               Int           @id @default(autoincrement())
  pedidoId         Int?          @map("pedido_id")
  clienteId        Int           @map("cliente_id")
  usuarioId        Int           @map("usuario_id")
  serie            String        @default("F001")
  correlativo      Int
  numeroFactura    String        @unique @map("numero_factura")
  subtotal         Decimal       @db.Decimal(10, 2)
  porcentajeIgv    Decimal       @default(18) @map("porcentaje_igv") @db.Decimal(5, 2)
  igv              Decimal       @db.Decimal(10, 2)
  total            Decimal       @db.Decimal(10, 2)
  detraccion       Decimal?      @db.Decimal(10, 2)
  porcentajeDetraccion Decimal?  @map("porcentaje_detraccion") @db.Decimal(5, 2)
  montoDetraccion  Decimal?      @map("monto_detraccion") @db.Decimal(10, 2)
  tipoCredito      String?       @map("tipo_credito")
  diasCredito      Int?          @map("dias_credito")
  guiaReferencia   String?       @map("guia_referencia")
  detalle          String?
  estado           EstadoFactura @default(EMITIDA)
  estadoSunat      String?       @map("estado_sunat")
  xmlPath          String?       @map("xml_path")
  pdfPath          String?       @map("pdf_path")
  cdrPath          String?       @map("cdr_path")
  hashXml          String?       @map("hash_xml")
  fechaEmision     DateTime      @default(now()) @map("fecha_emision")
  fechaVencimiento DateTime      @map("fecha_vencimiento")
  observaciones    String?
  totalPagado      Decimal       @default(0) @map("total_pagado") @db.Decimal(10, 2)
  creadoEn         DateTime      @default(now()) @map("creado_en")
  actualizadoEn    DateTime      @updatedAt @map("actualizado_en")

  pedido         Pedido?         @relation(fields: [pedidoId], references: [id])
  cliente        Cliente         @relation(fields: [clienteId], references: [id])
  usuario        Usuario         @relation(fields: [usuarioId], references: [id])
  pagos          Pago[]
  lineas         FacturaDetalle[]

  @@map("facturas")
}

model FacturaDetalle {
  id             Int      @id @default(autoincrement())
  facturaId      Int      @map("factura_id")
  orden          Int      @default(0)
  cantidad       Decimal  @db.Decimal(10, 3)
  unidadMedida   String   @default("NIU") @map("unidad_medida")
  codigo         String
  descripcion    String
  valorUnitario  Decimal  @map("valor_unitario") @db.Decimal(10, 2)
  importe        Decimal  @db.Decimal(10, 2)
  creadoEn       DateTime @default(now()) @map("creado_en")

  factura        Factura  @relation(fields: [facturaId], references: [id], onDelete: Cascade)

  @@map("factura_detalles")
}

model Pago {
  id             Int        @id @default(autoincrement())
  facturaId      Int        @map("factura_id")
  clienteId      Int        @map("cliente_id")
  usuarioId      Int        @map("usuario_id")
  monto          Decimal    @db.Decimal(10, 2)
  metodoPago     MetodoPago @map("metodo_pago")
  referencia     String?
  observaciones  String?
  fechaPago      DateTime   @default(now()) @map("fecha_pago")
  // Anulación lógica — no se elimina físicamente
  anulado        Boolean    @default(false)
  motivoAnulacion String?   @map("motivo_anulacion")
  anuladoEn      DateTime?  @map("anulado_en")
  creadoEn       DateTime   @default(now()) @map("creado_en")

  factura        Factura    @relation(fields: [facturaId], references: [id])
  cliente        Cliente    @relation(fields: [clienteId], references: [id])
  usuario        Usuario    @relation(fields: [usuarioId], references: [id])
  movimientosCaja MovimientoCaja[]

  @@map("pagos")
}

model Caja {
  id              Int        @id @default(autoincrement())
  usuarioId       Int        @map("usuario_id")
  nombre          String?
  fecha           DateTime   @db.Date
  saldoApertura   Decimal    @default(0) @map("saldo_apertura") @db.Decimal(10, 2)
  saldoCierre     Decimal?   @map("saldo_cierre") @db.Decimal(10, 2)
  estado          EstadoCaja @default(ABIERTA)
  observaciones   String?
  aperturaEn      DateTime   @default(now()) @map("apertura_en")
  cierreEn        DateTime?  @map("cierre_en")
  creadoEn        DateTime   @default(now()) @map("creado_en")
  actualizadoEn   DateTime   @updatedAt @map("actualizado_en")

  usuario         Usuario    @relation(fields: [usuarioId], references: [id])
  movimientos     MovimientoCaja[]

  @@map("cajas")
}

model MovimientoCaja {
  id              Int                @id @default(autoincrement())
  cajaId          Int                @map("caja_id")
  tipo            TipoMovimientoCaja
  monto           Decimal            @db.Decimal(10, 2)
  concepto        String
  // BUG 5 FIX: fecha editable y referencia externa
  fecha           DateTime?          @map("fecha")
  referencia      String?
  // MEJORA 2: anulación lógica (false = activo, true = anulado; default false)
  anulado         Boolean            @default(false)
  pagoId          Int?               @map("pago_id")
  gastoId         Int?               @map("gasto_id")
  creadoEn        DateTime           @default(now()) @map("creado_en")

  caja            Caja               @relation(fields: [cajaId], references: [id])
  pago            Pago?              @relation(fields: [pagoId], references: [id])

  @@map("movimientos_caja")
}

model Gasto {
  id              Int       @id @default(autoincrement())
  pedidoId        Int?      @map("pedido_id")
  usuarioId       Int       @map("usuario_id")
  tipoGasto       TipoGasto @map("tipo_gasto")
  monto           Decimal   @db.Decimal(10, 2)
  descripcion     String
  comprobante     String?
  fecha           DateTime  @default(now())
  creadoEn        DateTime  @default(now()) @map("creado_en")
  actualizadoEn   DateTime  @updatedAt @map("actualizado_en")

  pedido          Pedido?   @relation(fields: [pedidoId], references: [id])
  usuario         Usuario   @relation(fields: [usuarioId], references: [id])

  @@map("gastos")
}

model LogActividad {
  id         Int      @id @default(autoincrement())
  usuarioId  Int      @map("usuario_id")
  accion     String
  modulo     String
  detalle    String?
  ip         String?
  fechaHora  DateTime @default(now()) @map("fecha_hora")

  usuario    Usuario  @relation(fields: [usuarioId], references: [id])

  @@map("log_actividad")
}

// ─── CONDUCTOR ────────────────────────────────────────────────────────────────
model Conductor {
  id                  Int      @id @default(autoincrement())
  nombre              String
  dni                 String   @unique
  licencia            String
  vencimientoLicencia DateTime @map("vencimiento_licencia")
  telefono            String?
  direccion           String?
  activo              Boolean  @default(true)
  observaciones       String?
  tractoPreferencia   String?  @map("tracto_preferencia")
  carretaPreferencia  String?  @map("carreta_preferencia")
  creadoEn            DateTime @default(now()) @map("creado_en")
  actualizadoEn       DateTime @updatedAt @map("actualizado_en")

  liquidaciones       Liquidacion[]
  combustibles        Combustible[]

  @@map("conductores")
}

// ─── VEHICULO ─────────────────────────────────────────────────────────────────
enum TipoVehiculo {
  TRACTO
  CARRETA
}

model Vehiculo {
  id                   Int          @id @default(autoincrement())
  placa                String       @unique
  tipo                 TipoVehiculo
  marca                String
  modelo               String
  anio                 Int
  soat                 String?
  vencimientoSoat      DateTime?    @map("vencimiento_soat")
  revisionTecnica      String?      @map("revision_tecnica")
  vencimientoRevision  DateTime?    @map("vencimiento_revision")
  ultimoMantenimiento  DateTime?    @map("ultimo_mantenimiento")
  proximoMantenimiento DateTime?    @map("proximo_mantenimiento")
  estado               String       @default("OPERATIVO")
  observaciones        String?
  activo               Boolean      @default(true)
  creadoEn             DateTime     @default(now()) @map("creado_en")
  actualizadoEn        DateTime     @updatedAt @map("actualizado_en")

  combustibles         Combustible[]

  @@map("vehiculos")
}

// ─── LIQUIDACION ──────────────────────────────────────────────────────────────
model Liquidacion {
  id             Int                 @id @default(autoincrement())
  conductorId    Int                 @map("conductor_id")
  placaTracto    String              @map("placa_tracto")
  placaCarreta   String?             @map("placa_carreta")
  montoEntregado Decimal             @map("monto_entregado") @db.Decimal(10, 2)
  reciboAnticipo String?             @map("recibo_anticipo")
  fecha          DateTime
  guiaReferencia String?             @map("guia_referencia")
  observaciones  String?
  toldo          Decimal?            @db.Decimal(10, 2)
  totalGastos    Decimal             @default(0) @map("total_gastos") @db.Decimal(10, 2)
  devolucion     Decimal             @default(0) @db.Decimal(10, 2)
  reintegro      Decimal             @default(0) @db.Decimal(10, 2)
  estado         String              @default("PENDIENTE")
  creadoEn       DateTime            @default(now()) @map("creado_en")
  actualizadoEn  DateTime            @updatedAt @map("actualizado_en")

  conductor      Conductor           @relation(fields: [conductorId], references: [id])
  detalles       LiquidacionDetalle[]
  // NUEVO: pedidos relacionados
  pedidos        LiquidacionPedido[]

  @@map("liquidaciones")
}

enum CategoriaDetalle {
  PEAJE
  BALANZA
  VIATICO
  TOLDO
  OTROS
}

model LiquidacionDetalle {
  id             Int              @id @default(autoincrement())
  liquidacionId  Int              @map("liquidacion_id")
  categoria      CategoriaDetalle
  descripcion    String
  monto          Decimal          @db.Decimal(10, 2)

  liquidacion    Liquidacion      @relation(fields: [liquidacionId], references: [id], onDelete: Cascade)

  @@map("liquidacion_detalles")
}

// ─── NUEVO: PEDIDOS RELACIONADOS A LIQUIDACIÓN ────────────────────────────────
// Relación N:M explícita entre Liquidacion y Pedido.
// Restricción de negocio: un pedido solo puede estar en UNA liquidación activa
// (validado en el service, no solo aquí).
model LiquidacionPedido {
  id            Int         @id @default(autoincrement())
  liquidacionId Int         @map("liquidacion_id")
  pedidoId      Int         @map("pedido_id")
  creadoEn      DateTime    @default(now()) @map("creado_en")

  liquidacion   Liquidacion @relation(fields: [liquidacionId], references: [id], onDelete: Cascade)
  pedido        Pedido      @relation(fields: [pedidoId], references: [id])

  @@unique([liquidacionId, pedidoId])  // no duplicar mismo pedido en la misma liquidación
  @@map("liquidacion_pedidos")
}

// ─── COMBUSTIBLE ──────────────────────────────────────────────────────────────
model Combustible {
  id            Int       @id @default(autoincrement())
  vehiculoId    Int       @map("vehiculo_id")
  conductorId   Int?      @map("conductor_id")
  fecha         DateTime
  galones       Decimal   @db.Decimal(10, 3)
  monto         Decimal   @db.Decimal(10, 2)
  kilometraje   Decimal?  @db.Decimal(10, 2)
  grifo         String?
  observaciones String?
  creadoEn      DateTime  @default(now()) @map("creado_en")
  actualizadoEn DateTime  @updatedAt @map("actualizado_en")

  vehiculo      Vehiculo   @relation(fields: [vehiculoId], references: [id])
  conductor     Conductor? @relation(fields: [conductorId], references: [id])

  @@map("combustible")
}

// ─── CONFIGURACIÓN: PARÁMETROS GENERALES ─────────────────────────────────────
model Configuracion {
  id            Int      @id @default(autoincrement())
  clave         String   @unique
  valor         String
  tipo          String   @default("texto")
  categoria     String   @default("general")
  etiqueta      String
  descripcion   String?
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  @@map("configuraciones")
}

// ─── SERIES DE FACTURACIÓN ────────────────────────────────────────────────────
model SerieFacturacion {
  id                Int      @id @default(autoincrement())
  serie             String   @unique
  tipoDocumento     String   @default("FACTURA") @map("tipo_documento")
  correlativoActual Int      @default(1) @map("correlativo_actual")
  correlativoInicial Int     @default(1) @map("correlativo_inicial")
  activo            Boolean  @default(true)
  descripcion       String?
  creadoEn          DateTime @default(now()) @map("creado_en")
  actualizadoEn     DateTime @updatedAt @map("actualizado_en")

  @@map("series_facturacion")
}

// ─── CATEGORÍAS DE GASTO ──────────────────────────────────────────────────────
model CategoriaGasto {
  id            Int      @id @default(autoincrement())
  codigo        String   @unique
  nombre        String
  descripcion   String?
  activo        Boolean  @default(true)
  esDefault     Boolean  @default(false) @map("es_default")
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  @@map("categorias_gasto")
}

// ─── TABLA MAESTRA GENÉRICA ───────────────────────────────────────────────────
model TablaMaestra {
  id            Int      @id @default(autoincrement())
  tipo          String
  codigo        String
  nombre        String
  descripcion   String?
  extra         String?
  activo        Boolean  @default(true)
  orden         Int      @default(0)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  @@unique([tipo, codigo])
  @@map("tablas_maestras")
}

// ─── CONFIGURACIÓN DE ALERTAS ─────────────────────────────────────────────────
model ConfiguracionAlerta {
  id               Int      @id @default(autoincrement())
  clave            String   @unique
  etiqueta         String
  diasAnticipacion Int      @default(30) @map("dias_anticipacion")
  activo           Boolean  @default(true)
  color            String   @default("yellow")
  nivel            String   @default("warning")
  creadoEn         DateTime @default(now()) @map("creado_en")
  actualizadoEn    DateTime @updatedAt @map("actualizado_en")

  @@map("configuracion_alertas")
}

// ─── TIPOS DE VEHÍCULO ────────────────────────────────────────────────────────
model TipoVehiculoConfig {
  id            Int      @id @default(autoincrement())
  codigo        String   @unique
  nombre        String
  descripcion   String?
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  @@map("tipos_vehiculo_config")
}

// ─── PERMISOS DE MÓDULOS ──────────────────────────────────────────────────────
model PermisoModulo {
  id            Int      @id @default(autoincrement())
  usuarioId     Int      @map("usuario_id")
  moduloKey     String   @map("modulo_key")
  habilitado    Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, moduloKey])
  @@map("permisos_modulos")
}

// ─── PERMISOS DE ACCIONES ESPECIALES ────────────────────────────────────────
model PermisoAccion {
  id            Int      @id @default(autoincrement())
  usuarioId     Int      @map("usuario_id")
  accionKey     String   @map("accion_key")
  habilitado    Boolean  @default(false)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, accionKey])
  @@map("permisos_acciones")
}

// ─── MONEDAS ──────────────────────────────────────────────────────────────────
model Moneda {
  id            Int      @id @default(autoincrement())
  codigo        String   @unique
  nombre        String
  simbolo       String
  esPorDefecto  Boolean  @default(false) @map("es_por_defecto")
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  cuentas           CuentaDinero[]
  movimientos       MovimientoCuentaV2[]
  pagosV2           PagoV2[]

  @@map("monedas")
}

// ─── TIPOS DE PAGO ────────────────────────────────────────────────────────────
model TipoPago {
  id            Int      @id @default(autoincrement())
  codigo        String   @unique
  nombre        String
  descripcion   String?
  orden         Int      @default(0)
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  movimientos   MovimientoCuentaV2[]
  pagosV2       PagoV2[]

  @@map("tipos_pago")
}

// ─── CUENTAS DE DINERO ────────────────────────────────────────────────────────
model CuentaDinero {
  id            Int      @id @default(autoincrement())
  nombre        String
  tipoCuenta    String   @map("tipo_cuenta")
  monedaId      Int      @map("moneda_id")
  saldoInicial  Decimal  @default(0) @map("saldo_inicial") @db.Decimal(12, 2)
  saldoActual   Decimal  @default(0) @map("saldo_actual") @db.Decimal(12, 2)
  descripcion   String?
  banco         String?
  numeroCuenta  String?  @map("numero_cuenta")
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  moneda        Moneda   @relation(fields: [monedaId], references: [id])
  movimientos   MovimientoCuentaV2[] @relation("CuentaOrigen")
  movimientosDestino MovimientoCuentaV2[] @relation("CuentaDestino")

  @@map("cuentas_dinero")
}

// ─── MOVIMIENTOS DE CUENTA V2 ─────────────────────────────────────────────────
model MovimientoCuentaV2 {
  id               Int      @id @default(autoincrement())
  cuentaId         Int      @map("cuenta_id")
  tipo             String   // INGRESO | EGRESO | TRANSFERENCIA
  monto            Decimal  @db.Decimal(12, 2)
  monedaId         Int      @map("moneda_id")
  tipoPagoId       Int?     @map("tipo_pago_id")
  concepto         String
  referencia       String?
  cuentaDestinoId  Int?     @map("cuenta_destino_id")
  usuarioId        Int      @map("usuario_id")
  fecha            DateTime @default(now())
  creadoEn         DateTime @default(now()) @map("creado_en")

  cuenta           CuentaDinero @relation("CuentaOrigen", fields: [cuentaId], references: [id])
  moneda           Moneda       @relation(fields: [monedaId], references: [id])
  tipoPago         TipoPago?    @relation(fields: [tipoPagoId], references: [id])
  cuentaDestino    CuentaDinero? @relation("CuentaDestino", fields: [cuentaDestinoId], references: [id])
  usuario          Usuario      @relation(fields: [usuarioId], references: [id])

  @@map("movimientos_cuenta_v2")
}

// ─── PAGOS V2 ─────────────────────────────────────────────────────────────────
model PagoV2 {
  id            Int      @id @default(autoincrement())
  facturaId     Int?     @map("factura_id")
  clienteId     Int?     @map("cliente_id")
  usuarioId     Int      @map("usuario_id")
  monto         Decimal  @db.Decimal(12, 2)
  monedaId      Int      @map("moneda_id")
  tipoPagoId    Int?     @map("tipo_pago_id")
  referencia    String?
  observaciones String?
  fechaPago     DateTime @default(now()) @map("fecha_pago")
  creadoEn      DateTime @default(now()) @map("creado_en")

  moneda        Moneda   @relation(fields: [monedaId], references: [id])
  tipoPago      TipoPago? @relation(fields: [tipoPagoId], references: [id])
  usuario       Usuario  @relation(fields: [usuarioId], references: [id])

  @@map("pagos_v2")
}
