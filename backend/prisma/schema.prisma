// FILE: prisma/schema.prisma
// CAMBIO: Cobranza (aplicación de pagos a múltiples facturas), Mantenimiento
// (relación de egresos a vehículo/conductor/motivo), categoría de ingreso en
// MovimientoCuentaV2 y auditoría (creadoPor/actualizadoPor) en todos los
// modelos de primer nivel.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Rol {
  ADMIN
  SECRETARIO
  CHOFER
}

enum EstadoPedido {
  ACTIVO
  FACTURADO
  ANULADO
}

enum EstadoFactura {
  EMITIDA
  PAGADA
  PENDIENTE
  PARCIAL
  ANULADA
}

enum EstadoCaja {
  ABIERTA
  CERRADA
}

enum TipoMovimientoCaja {
  INGRESO
  EGRESO
}

// ─── MODELOS ─────────────────────────────────────────────────────────────────

model Usuario {
  id            Int       @id @default(autoincrement())
  nombre        String
  email         String    @unique
  passwordHash  String    @map("password_hash")
  rol           Rol       @default(SECRETARIO)
  activo        Boolean   @default(true)
  ultimoAcceso  DateTime? @map("ultimo_acceso")
  creadoEn      DateTime  @default(now()) @map("creado_en")
  actualizadoEn DateTime  @updatedAt @map("actualizado_en")

  // ── Restricción de horario de acceso (por usuario) ──────────────────────
  // Si restriccionHorarioActiva es true, el usuario solo puede iniciar sesión
  // y usar el sistema dentro de diasPermitidos (1=Lunes...7=Domingo) y entre
  // horaInicio y horaFin ("HH:mm", hora Perú). ADMIN nunca se restringe.
  restriccionHorarioActiva Boolean @default(false) @map("restriccion_horario_activa")
  diasPermitidos           Int[]   @default([1, 2, 3, 4, 5]) @map("dias_permitidos")
  horaInicio               String? @map("hora_inicio")
  horaFin                  String? @map("hora_fin")

  // ── Vínculo Usuario (rol CHOFER) ↔ Conductor ─────────────────────────────
  // Permite que la cuenta de login de un chofer sepa qué ficha de Conductor
  // le corresponde (para preasignarlo en las guías que crea desde el celular).
  conductorId Int?       @unique @map("conductor_id")
  conductor   Conductor? @relation("UsuarioChofer", fields: [conductorId], references: [id])

  // ── Link/QR fijo de acceso (solo rol CHOFER) ─────────────────────────────
  // Hash SHA-256 del token opaco que se entrega como link/QR permanente para
  // que el chofer entre directo a Guías sin escribir usuario/contraseña. Se
  // guarda hasheado (no el token en texto plano) para que un volcado de la
  // base de datos no exponga credenciales usables directamente.
  accessTokenHash String? @unique @map("access_token_hash")

  pedidos  Pedido[]
  facturas Factura[]
  cajas    Caja[]
  logs     LogActividad[]

  permisosModulos     PermisoModulo[]
  permisosAcciones    PermisoAccion[]
  movimientosCuentaV2 MovimientoCuentaV2[]
  pagosV2             PagoV2[]
  guias               Guia[]

  // ── Auditoría: back-relations de "creado por" / "actualizado por" ────────
  clientesCreados               Cliente[]                 @relation("ClienteCreadoPor")
  clientesActualizados          Cliente[]                 @relation("ClienteActualizadoPor")
  pedidosCreados                Pedido[]                  @relation("PedidoCreadoPor")
  pedidosActualizados           Pedido[]                  @relation("PedidoActualizadoPor")
  facturasCreadas               Factura[]                 @relation("FacturaCreadoPor")
  facturasActualizadas          Factura[]                 @relation("FacturaActualizadoPor")
  vehiculosCreados              Vehiculo[]                @relation("VehiculoCreadoPor")
  vehiculosActualizados         Vehiculo[]                @relation("VehiculoActualizadoPor")
  conductoresCreados            Conductor[]               @relation("ConductorCreadoPor")
  conductoresActualizados       Conductor[]               @relation("ConductorActualizadoPor")
  cuentasCreadas                CuentaDinero[]            @relation("CuentaDineroCreadoPor")
  cuentasActualizadas           CuentaDinero[]            @relation("CuentaDineroActualizadoPor")
  movimientosCuentaCreados      MovimientoCuentaV2[]      @relation("MovimientoCuentaV2CreadoPor")
  movimientosCuentaActualizados MovimientoCuentaV2[]      @relation("MovimientoCuentaV2ActualizadoPor")
  pagosV2Creados                PagoV2[]                  @relation("PagoV2CreadoPor")
  pagosV2Actualizados           PagoV2[]                  @relation("PagoV2ActualizadoPor")
  aplicacionesFacturaCreadas    PagoV2AplicacionFactura[] @relation("AplicacionFacturaCreadoPor")
  liquidacionesCreadas          Liquidacion[]             @relation("LiquidacionCreadoPor")
  liquidacionesActualizadas     Liquidacion[]             @relation("LiquidacionActualizadoPor")
  cajasCreadas                  Caja[]                    @relation("CajaCreadoPor")
  cajasActualizadas             Caja[]                    @relation("CajaActualizadoPor")
  movimientosCajaCreados        MovimientoCaja[]          @relation("MovimientoCajaCreadoPor")
  combustiblesCreados           Combustible[]             @relation("CombustibleCreadoPor")
  combustiblesActualizados      Combustible[]             @relation("CombustibleActualizadoPor")
  configuracionesCreadas        Configuracion[]           @relation("ConfiguracionCreadoPor")
  configuracionesActualizadas   Configuracion[]           @relation("ConfiguracionActualizadoPor")
  seriesFacturacionCreadas      SerieFacturacion[]        @relation("SerieFacturacionCreadoPor")
  seriesFacturacionActualizadas SerieFacturacion[]        @relation("SerieFacturacionActualizadoPor")
  tablasMaestrasCreadas         TablaMaestra[]            @relation("TablaMaestraCreadoPor")
  tablasMaestrasActualizadas    TablaMaestra[]            @relation("TablaMaestraActualizadoPor")
  alertasCreadas                ConfiguracionAlerta[]     @relation("ConfiguracionAlertaCreadoPor")
  alertasActualizadas           ConfiguracionAlerta[]     @relation("ConfiguracionAlertaActualizadoPor")
  tiposVehiculoCreados          TipoVehiculoConfig[]      @relation("TipoVehiculoConfigCreadoPor")
  tiposVehiculoActualizados     TipoVehiculoConfig[]      @relation("TipoVehiculoConfigActualizadoPor")
  monedasCreadas                Moneda[]                  @relation("MonedaCreadoPor")
  monedasActualizadas           Moneda[]                  @relation("MonedaActualizadoPor")
  tiposPagoCreados              TipoPago[]                @relation("TipoPagoCreadoPor")
  tiposPagoActualizados         TipoPago[]                @relation("TipoPagoActualizadoPor")
  guiasCreadas                  Guia[]                    @relation("GuiaCreadoPor")
  guiasActualizadas             Guia[]                    @relation("GuiaActualizadoPor")
  mantenimientosCreados         MantenimientoDetalle[]    @relation("MantenimientoCreadoPor")
  mantenimientosActualizados    MantenimientoDetalle[]    @relation("MantenimientoActualizadoPor")

  @@map("usuarios")
}

model Cliente {
  id               Int           @id @default(autoincrement())
  razonSocial      String        @map("razon_social")
  ruc              String        @unique
  direccion        String
  // Ubigeo (código INEI de 6 dígitos) del cliente — se usa para autocompletar
  // el punto de llegada al seleccionar el cliente en una Guía de Remisión.
  ubigeo           String?
  telefono         String?
  email            String?
  // Antes era un enum fijo (CONTADO/CREDITO_15/30/60). Ahora guarda 'CONTADO'
  // o el código de un registro activo de TablaMaestra tipo='tipo_credito',
  // para que Configuración → Tablas Maestras controle las opciones reales.
  condicionPago    String        @default("CONTADO") @map("condicion_pago")
  activo           Boolean       @default(true)
  creadoEn         DateTime      @default(now()) @map("creado_en")
  actualizadoEn    DateTime      @updatedAt @map("actualizado_en")
  creadoPorId      Int?          @map("creado_por_id")
  actualizadoPorId Int?          @map("actualizado_por_id")

  pedidos        Pedido[]
  facturas       Factura[]
  pagosV2        PagoV2[]
  contactos      ClienteContacto[]
  guias          Guia[]    @relation("GuiaDestinatario")
  guiasRemitente Guia[]    @relation("GuiaRemitente")
  creadoPor      Usuario?  @relation("ClienteCreadoPor", fields: [creadoPorId], references: [id])
  actualizadoPor Usuario?  @relation("ClienteActualizadoPor", fields: [actualizadoPorId], references: [id])

  @@map("clientes")
}

// Contactos adicionales de un cliente (nombre, teléfono, correo). El
// teléfono/email "principal" sigue viviendo en Cliente.telefono/email; esta
// tabla permite registrar contactos extra sin perder esos campos existentes.
model ClienteContacto {
  id        Int      @id @default(autoincrement())
  clienteId Int      @map("cliente_id")
  nombre    String
  telefono  String?
  email     String?
  creadoEn  DateTime @default(now()) @map("creado_en")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("clientes_contactos")
}

model Pedido {
  id               Int          @id @default(autoincrement())
  clienteId        Int          @map("cliente_id")
  usuarioId        Int          @map("usuario_id")
  origen           String
  destino          String
  tipoCarga        String       @map("tipo_carga")
  vehiculoId       Int?         @map("vehiculo_id")
  tarifa           Decimal      @db.Decimal(10, 2)
  estado           EstadoPedido @default(ACTIVO)
  observaciones    String?
  fechaPedido      DateTime     @default(now()) @map("fecha_pedido")
  creadoEn         DateTime     @default(now()) @map("creado_en")
  actualizadoEn    DateTime     @updatedAt @map("actualizado_en")
  creadoPorId      Int?         @map("creado_por_id")
  actualizadoPorId Int?         @map("actualizado_por_id")

  cliente        Cliente             @relation(fields: [clienteId], references: [id])
  usuario        Usuario             @relation(fields: [usuarioId], references: [id])
  vehiculo       Vehiculo?           @relation(fields: [vehiculoId], references: [id])
  facturas       Factura[]
  // NUEVO: relación con liquidaciones
  liquidaciones  LiquidacionPedido[]
  guias          Guia[]
  creadoPor      Usuario?            @relation("PedidoCreadoPor", fields: [creadoPorId], references: [id])
  actualizadoPor Usuario?            @relation("PedidoActualizadoPor", fields: [actualizadoPorId], references: [id])

  @@map("pedidos")
}

model Factura {
  id                   Int           @id @default(autoincrement())
  pedidoId             Int?          @map("pedido_id")
  clienteId            Int           @map("cliente_id")
  usuarioId            Int           @map("usuario_id")
  serie                String        @default("F001")
  correlativo          Int
  numeroFactura        String        @unique @map("numero_factura")
  subtotal             Decimal       @db.Decimal(10, 2)
  porcentajeIgv        Decimal       @default(18) @map("porcentaje_igv") @db.Decimal(5, 2)
  igv                  Decimal       @db.Decimal(10, 2)
  total                Decimal       @db.Decimal(10, 2)
  detraccion           Decimal?      @db.Decimal(10, 2)
  porcentajeDetraccion Decimal?      @map("porcentaje_detraccion") @db.Decimal(5, 2)
  montoDetraccion      Decimal?      @map("monto_detraccion") @db.Decimal(10, 2)
  tipoCredito          String?       @map("tipo_credito")
  diasCredito          Int?          @map("dias_credito")
  guiaReferencia       String?       @map("guia_referencia")
  peso                 Decimal?      @db.Decimal(10, 2)
  detalle              String?
  estado               EstadoFactura @default(EMITIDA)
  estadoSunat          String?       @map("estado_sunat")
  xmlPath              String?       @map("xml_path")
  pdfPath              String?       @map("pdf_path")
  cdrPath              String?       @map("cdr_path")
  hashXml              String?       @map("hash_xml")
  fechaEmision         DateTime      @default(now()) @map("fecha_emision")
  fechaVencimiento     DateTime      @map("fecha_vencimiento")
  observaciones        String?
  totalPagado          Decimal       @default(0) @map("total_pagado") @db.Decimal(10, 2)
  creadoEn             DateTime      @default(now()) @map("creado_en")
  actualizadoEn        DateTime      @updatedAt @map("actualizado_en")
  creadoPorId          Int?          @map("creado_por_id")
  actualizadoPorId     Int?          @map("actualizado_por_id")

  pedido           Pedido?                   @relation(fields: [pedidoId], references: [id])
  cliente          Cliente                   @relation(fields: [clienteId], references: [id])
  usuario          Usuario                   @relation(fields: [usuarioId], references: [id])
  pagosV2          PagoV2[]
  aplicacionesPago PagoV2AplicacionFactura[]
  lineas           FacturaDetalle[]
  guias            Guia[]
  creadoPor        Usuario?                  @relation("FacturaCreadoPor", fields: [creadoPorId], references: [id])
  actualizadoPor   Usuario?                  @relation("FacturaActualizadoPor", fields: [actualizadoPorId], references: [id])

  @@map("facturas")
}

model FacturaDetalle {
  id            Int      @id @default(autoincrement())
  facturaId     Int      @map("factura_id")
  orden         Int      @default(0)
  cantidad      Decimal  @db.Decimal(10, 3)
  unidadMedida  String   @default("NIU") @map("unidad_medida")
  codigo        String?
  descripcion   String
  valorUnitario Decimal  @map("valor_unitario") @db.Decimal(10, 2)
  importe       Decimal  @db.Decimal(10, 2)
  creadoEn      DateTime @default(now()) @map("creado_en")

  factura Factura @relation(fields: [facturaId], references: [id], onDelete: Cascade)

  @@map("factura_detalles")
}

model Caja {
  id                 Int        @id @default(autoincrement())
  usuarioId          Int        @map("usuario_id")
  nombre             String?
  fecha              DateTime   @db.Date
  saldoApertura      Decimal    @default(0) @map("saldo_apertura") @db.Decimal(10, 2)
  saldoCierre        Decimal?   @map("saldo_cierre") @db.Decimal(10, 2)
  estado             EstadoCaja @default(ABIERTA)
  observaciones      String?
  // Cuenta de dinero de la que se retira el efectivo de apertura (genera un
  // movimiento de salida automático en esa cuenta). Nullable solo por
  // compatibilidad con cajas históricas; el flujo de apertura la exige.
  cuentaOrigenId     Int?       @map("cuenta_origen_id")
  // Cuenta destino donde se devuelve el saldo restante al cerrar la caja.
  // Si se establece, significa que ya se generó el movimiento de devolución.
  cuentaDestinoId    Int?       @map("cuenta_destino_id")
  // Módulo Movimientos: egreso (categoría CAJA_CHICA) del que se abrió esta caja.
  // Un mismo egreso solo puede abrir una caja (@unique). Nullable por compatibilidad
  // con cajas históricas, que generaban su propio egreso identificado por referencia.
  movimientoCuentaId Int?       @unique @map("movimiento_cuenta_id")
  // Ingreso (devolución de saldo) generado automáticamente al cerrar esta caja
  // con cuenta destino. @unique porque cada cierre genera a lo más un ingreso.
  // Vía este vínculo (en vez de `referencia`) se identifica el ingreso como
  // "devolución de caja chica" — `referencia` queda libre para que el usuario
  // escriba el N° de operación bancario real de esa devolución.
  movimientoCierreId Int?       @unique @map("movimiento_cierre_id")
  aperturaEn         DateTime   @default(now()) @map("apertura_en")
  cierreEn           DateTime?  @map("cierre_en")
  creadoEn           DateTime   @default(now()) @map("creado_en")
  actualizadoEn      DateTime   @updatedAt @map("actualizado_en")
  creadoPorId        Int?       @map("creado_por_id")
  actualizadoPorId   Int?       @map("actualizado_por_id")

  usuario          Usuario             @relation(fields: [usuarioId], references: [id])
  cuentaOrigen     CuentaDinero?       @relation("CajaOrigen", fields: [cuentaOrigenId], references: [id])
  cuentaDestino    CuentaDinero?       @relation("CajaDestino", fields: [cuentaDestinoId], references: [id])
  movimientoCuenta MovimientoCuentaV2? @relation("CajaApertura", fields: [movimientoCuentaId], references: [id])
  movimientoCierre MovimientoCuentaV2? @relation("CajaCierre", fields: [movimientoCierreId], references: [id])
  movimientos      MovimientoCaja[]
  creadoPor        Usuario?            @relation("CajaCreadoPor", fields: [creadoPorId], references: [id])
  actualizadoPor   Usuario?            @relation("CajaActualizadoPor", fields: [actualizadoPorId], references: [id])

  @@map("cajas")
}

model MovimientoCaja {
  id                 Int                @id @default(autoincrement())
  cajaId             Int                @map("caja_id")
  tipo               TipoMovimientoCaja
  monto              Decimal            @db.Decimal(10, 2)
  concepto           String
  // BUG 5 FIX: fecha editable y referencia externa
  fecha              DateTime?          @map("fecha")
  referencia         String?
  // Categoría del egreso (mismo catálogo que Movimientos: TablaMaestra tipo
  // 'categoria_egreso'), requerida para movimientos EGRESO. Permite que un
  // gasto pagado con caja chica (ej. mantenimiento) sea visible en los mismos
  // reportes que los egresos registrados en Movimientos.
  categoriaEgreso    String?            @map("categoria_egreso")
  // Vehículo asociado, opcional — habilita agrupar por vehículo en el reporte
  // de Mantenimiento cuando categoriaEgreso = MANTENIMIENTO.
  vehiculoId         Int?               @map("vehiculo_id")
  // MEJORA 2: anulación lógica (false = activo, true = anulado; default false)
  anulado            Boolean            @default(false)
  pagoId             Int?               @map("pago_id")
  gastoId            Int?               @map("gasto_id")
  // CHAT 9: vínculo con MovimientoCuentaV2 (nullable para compatibilidad histórica)
  movimientoCuentaId Int?               @map("movimiento_cuenta_id")
  creadoEn           DateTime           @default(now()) @map("creado_en")
  creadoPorId        Int?               @map("creado_por_id")

  caja             Caja                @relation(fields: [cajaId], references: [id])
  vehiculo         Vehiculo?           @relation(fields: [vehiculoId], references: [id])
  movimientoCuenta MovimientoCuentaV2? @relation("MovCajaCuenta", fields: [movimientoCuentaId], references: [id])
  creadoPor        Usuario?            @relation("MovimientoCajaCreadoPor", fields: [creadoPorId], references: [id])

  @@map("movimientos_caja")
}

model LogActividad {
  id        Int      @id @default(autoincrement())
  usuarioId Int      @map("usuario_id")
  accion    String
  modulo    String
  detalle   String?
  ip        String?
  fechaHora DateTime @default(now()) @map("fecha_hora")

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([fechaHora])
  @@map("log_actividad")
}

// ─── CONDUCTOR ────────────────────────────────────────────────────────────────
model Conductor {
  id                  Int      @id @default(autoincrement())
  nombre              String
  dni                 String   @unique
  licencia            String
  vencimientoLicencia DateTime? @map("vencimiento_licencia")
  telefono            String?
  direccion           String?
  activo              Boolean  @default(true)
  observaciones       String?
  tractoPreferencia   String?  @map("tracto_preferencia")
  carretaPreferencia  String?  @map("carreta_preferencia")
  creadoEn            DateTime @default(now()) @map("creado_en")
  actualizadoEn       DateTime @updatedAt @map("actualizado_en")
  creadoPorId         Int?     @map("creado_por_id")
  actualizadoPorId    Int?     @map("actualizado_por_id")

  liquidaciones  Liquidacion[]
  combustibles   Combustible[]
  guias          Guia[]
  mantenimientos MantenimientoDetalle[]
  creadoPor      Usuario?               @relation("ConductorCreadoPor", fields: [creadoPorId], references: [id])
  actualizadoPor Usuario?               @relation("ConductorActualizadoPor", fields: [actualizadoPorId], references: [id])
  usuarioChofer  Usuario?               @relation("UsuarioChofer")

  @@map("conductores")
}

// ─── VEHICULO ─────────────────────────────────────────────────────────────────
enum TipoVehiculo {
  TRACTO
  CARRETA
}

model Vehiculo {
  id                   Int          @id @default(autoincrement())
  placa                String       @unique
  tipo                 TipoVehiculo
  marca                String?
  modelo               String?
  anio                 Int?
  soat                 String?
  vencimientoSoat      DateTime?    @map("vencimiento_soat")
  revisionTecnica      String?      @map("revision_tecnica")
  vencimientoRevision  DateTime?    @map("vencimiento_revision")
  ultimoMantenimiento  DateTime?    @map("ultimo_mantenimiento")
  proximoMantenimiento DateTime?    @map("proximo_mantenimiento")
  estado               String       @default("OPERATIVO")
  observaciones        String?
  activo               Boolean      @default(true)
  creadoEn             DateTime     @default(now()) @map("creado_en")
  actualizadoEn        DateTime     @updatedAt @map("actualizado_en")
  creadoPorId          Int?         @map("creado_por_id")
  actualizadoPorId     Int?         @map("actualizado_por_id")

  combustibles     Combustible[]
  guias            Guia[]
  guiasComoCarreta Guia[]                 @relation("GuiaVehiculoCarreta")
  mantenimientos   MantenimientoDetalle[]
  movimientosCaja  MovimientoCaja[]
  pedidos          Pedido[]
  creadoPor        Usuario?               @relation("VehiculoCreadoPor", fields: [creadoPorId], references: [id])
  actualizadoPor   Usuario?               @relation("VehiculoActualizadoPor", fields: [actualizadoPorId], references: [id])

  @@map("vehiculos")
}

// ─── LIQUIDACION ──────────────────────────────────────────────────────────────
model Liquidacion {
  id               Int       @id @default(autoincrement())
  conductorId      Int       @map("conductor_id")
  placaTracto      String    @map("placa_tracto")
  placaCarreta     String?   @map("placa_carreta")
  montoEntregado   Decimal   @map("monto_entregado") @db.Decimal(10, 2)
  reciboAnticipo   String?   @map("recibo_anticipo")
  fecha            DateTime
  guiaReferencia   String?   @map("guia_referencia")
  observaciones    String?
  toldo            Decimal?  @db.Decimal(10, 2)
  totalGastos      Decimal   @default(0) @map("total_gastos") @db.Decimal(10, 2)
  devolucion       Decimal   @default(0) @db.Decimal(10, 2)
  reintegro        Decimal   @default(0) @db.Decimal(10, 2)
  // Flujo: CREADA → PAGADA → RENDIDA → CERRADA
  // (legacy: PENDIENTE_RENDICION, PENDIENTE mapeados a CREADA en la lógica de servicio)
  estado           String    @default("CREADA")
  // Campos del nuevo flujo
  fechaPago        DateTime? @map("fecha_pago")
  montoPagado      Decimal?  @map("monto_pagado") @db.Decimal(10, 2)
  fechaRendicion   DateTime? @map("fecha_rendicion")
  montoRendido     Decimal?  @map("monto_rendido") @db.Decimal(10, 2)
  fechaCierre      DateTime? @map("fecha_cierre")
  montoDevolucion  Decimal?  @map("monto_devolucion") @db.Decimal(10, 2)
  tipoAjuste       String?   @map("tipo_ajuste")
  creadoEn         DateTime  @default(now()) @map("creado_en")
  actualizadoEn    DateTime  @updatedAt @map("actualizado_en")
  creadoPorId      Int?      @map("creado_por_id")
  actualizadoPorId Int?      @map("actualizado_por_id")

  conductor         Conductor            @relation(fields: [conductorId], references: [id])
  detalles          LiquidacionDetalle[]
  // NUEVO: pedidos relacionados
  pedidos           LiquidacionPedido[]
  // CHAT 9: movimientos de cuenta asociados a pagos de esta liquidación
  movimientosCuenta MovimientoCuentaV2[] @relation("LiquidacionPago")
  // P4: cargas de combustible asociadas a esta liquidación
  combustibles      Combustible[]
  creadoPor         Usuario?             @relation("LiquidacionCreadoPor", fields: [creadoPorId], references: [id])
  actualizadoPor    Usuario?             @relation("LiquidacionActualizadoPor", fields: [actualizadoPorId], references: [id])

  @@map("liquidaciones")
}

enum CategoriaDetalle {
  PEAJE
  BALANZA
  VIATICO
  TOLDO
  OTROS
}

model LiquidacionDetalle {
  id            Int              @id @default(autoincrement())
  liquidacionId Int              @map("liquidacion_id")
  categoria     CategoriaDetalle
  descripcion   String
  monto         Decimal          @db.Decimal(10, 2)

  liquidacion Liquidacion @relation(fields: [liquidacionId], references: [id], onDelete: Cascade)

  @@map("liquidacion_detalles")
}

// ─── NUEVO: PEDIDOS RELACIONADOS A LIQUIDACIÓN ────────────────────────────────
// Relación N:M explícita entre Liquidacion y Pedido.
// Restricción de negocio: un pedido solo puede estar en UNA liquidación activa
// (validado en el service, no solo aquí).
model LiquidacionPedido {
  id            Int      @id @default(autoincrement())
  liquidacionId Int      @map("liquidacion_id")
  pedidoId      Int      @map("pedido_id")
  creadoEn      DateTime @default(now()) @map("creado_en")

  liquidacion Liquidacion @relation(fields: [liquidacionId], references: [id], onDelete: Cascade)
  pedido      Pedido      @relation(fields: [pedidoId], references: [id])

  @@unique([liquidacionId, pedidoId]) // no duplicar mismo pedido en la misma liquidación
  @@map("liquidacion_pedidos")
}

// ─── COMBUSTIBLE ──────────────────────────────────────────────────────────────
model Combustible {
  id               Int      @id @default(autoincrement())
  vehiculoId       Int      @map("vehiculo_id")
  conductorId      Int?     @map("conductor_id")
  // P4: liquidación del conductor a la que se asocia esta carga (opcional)
  liquidacionId    Int?     @map("liquidacion_id")
  fecha            DateTime
  galones          Decimal  @db.Decimal(10, 3)
  monto            Decimal  @db.Decimal(10, 2)
  kilometraje      Decimal? @db.Decimal(10, 2)
  grifo            String?
  observaciones    String?
  creadoEn         DateTime @default(now()) @map("creado_en")
  actualizadoEn    DateTime @updatedAt @map("actualizado_en")
  creadoPorId      Int?     @map("creado_por_id")
  actualizadoPorId Int?     @map("actualizado_por_id")

  // Módulo Movimientos: egreso (categoría COMBUSTIBLE) del que se descuenta esta
  // carga. Nullable por compatibilidad con cargas históricas (creadas antes de
  // este vínculo, que generaban su propio egreso identificado por referencia).
  movimientoCuentaId Int? @map("movimiento_cuenta_id")

  vehiculo         Vehiculo            @relation(fields: [vehiculoId], references: [id])
  conductor        Conductor?          @relation(fields: [conductorId], references: [id])
  liquidacion      Liquidacion?        @relation(fields: [liquidacionId], references: [id])
  movimientoCuenta MovimientoCuentaV2? @relation(fields: [movimientoCuentaId], references: [id])
  creadoPor        Usuario?            @relation("CombustibleCreadoPor", fields: [creadoPorId], references: [id])
  actualizadoPor   Usuario?            @relation("CombustibleActualizadoPor", fields: [actualizadoPorId], references: [id])

  @@map("combustible")
}

