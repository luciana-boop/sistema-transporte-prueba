# ─────────────────────────────────────────────────────────────────────────────
# Copiá este archivo como .env y completá los valores ANTES de arrancar.
# NUNCA comitees el archivo .env al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# Base de datos
DATABASE_URL="postgresql://USUARIO:CONTRASEÑA@localhost:5432/transportes"

# JWT — OBLIGATORIO: generá un secreto seguro con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NO uses "supersecret123" ni ningún valor predecible.
JWT_SECRET="REEMPLAZAR_CON_SECRETO_ALEATORIO_DE_64_BYTES"

# Tiempo de expiración del token (recomendado: 2h o menos)
JWT_EXPIRES_IN="2h"

# Entorno: development | production
NODE_ENV="development"

# Puerto del servidor
PORT=3001

# Orígenes permitidos para CORS (separados por coma si son varios)
# Ejemplo producción: CORS_ORIGIN="https://mi-app.com"
# En desarrollo con localhost no hace falta definirlo.
CORS_ORIGIN=""

# Rondas de bcrypt (12 es seguro; subir a 13-14 en producción si el hardware lo permite)
BCRYPT_ROUNDS=12
